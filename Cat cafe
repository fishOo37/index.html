<!DOCTYPE html>
<html>
<head>
<title>My Warm Cat Café Forest</title>

<style>
    body {
        margin: 0;
        padding: 0;
        font-family: "Georgia", serif;
        background-image: url('https://images.unsplash.com/photo-1501785888041-af3ef285b470?auto=format&fit=crop&w=1950&q=80');
        background-size: cover;
        background-position: center;
        color: #4a3b2a;
        text-shadow: 0 0 4px rgba(255, 240, 210, 0.7);
        overflow-x: hidden;
    }

    .overlay {
        background: rgba(255, 235, 210, 0.45);
        backdrop-filter: blur(3px);
        min-height: 100vh;
        padding: 40px;
    }

    h1 {
        font-size: 42px;
        margin-bottom: 10px;
    }

    .section {
        background: rgba(255, 250, 240, 0.7);
        padding: 20px;
        border-radius: 14px;
        margin: 20px 0;
        max-width: 650px;
        box-shadow: 0 0 10px rgba(120, 90, 60, 0.2);
    }

    a {
        color: #6b4f3a;
        font-weight: bold;
        text-decoration: none;
    }

    a:hover {
        text-decoration: underline;
    }

    /* Café Magic Button */
    #magicButton {
        position: fixed;
        top: 20px;
        right: 20px;
        background: #f7e3c3;
        border: 2px solid #b08a63;
        padding: 12px 20px;
        border-radius: 12px;
        font-size: 18px;
        cursor: pointer;
        box-shadow: 0 0 10px rgba(120, 90, 60, 0.3);
        transition: 0.2s;
    }

    #magicButton:hover {
        background: #f3d7ad;
        transform: scale(1.05);
    }

    /* Corner Cats */
    #cat1, #cat2 {
        position: fixed;
        width: 120px;
        cursor: pointer;
        transition: transform 0.2s ease;
    }

    #cat1 { bottom: 20px; right: 20px; }
    #cat2 { bottom: 20px; left: 20px; }

    #cat1:hover, #cat2:hover {
        transform: scale(1.1);
    }

    /* Petals */
    .petal {
        position: fixed;
        top: -10px;
        width: 20px;
        height: 20px;
        background: pink;
        border-radius: 50%;
        opacity: 0.7;
        animation: fall 8s linear infinite;
        display: none;
    }

    @keyframes fall {
        0% { transform: translateY(0) rotate(0deg); }
        100% { transform: translateY(120vh) rotate(360deg); }
    }

    /* Fireflies */
    .firefly {
        position: fixed;
        width: 6px;
        height: 6px;
        background: rgba(255, 255, 200, 0.8);
        border-radius: 50%;
        box-shadow: 0 0 8px rgba(255, 255, 200, 1);
        animation: drift 6s ease-in-out infinite;
        display: none;
    }

    @keyframes drift {
        0% { transform: translate(0, 0); }
        50% { transform: translate(40px, -20px); }
        100% { transform: translate(0, 0); }
    }

    /* Steam */
    .steam {
        position: fixed;
        bottom: 120px;
        right: 80px;
        width: 20px;
        height: 40px;
        background: rgba(255, 255, 255, 0.5);
        border-radius: 50%;
        filter: blur(8px);
        animation: steamRise 4s infinite;
        display: none;
    }

    @keyframes steamRise {
        0% { transform: translateY(0) scale(1); opacity: 0.6; }
        100% { transform: translateY(-80px) scale(1.4); opacity: 0; }
    }

    /* Chalkboard Menu */
    #menuBoard {
        position: fixed;
        top: 120px;
        left: 20px;
        width: 200px;
        padding: 20px;
        background: #2b2b2b;
        color: #f5f5f5;
        border: 4px solid #3d3d3d;
        border-radius: 10px;
        font-family: "Courier New", monospace;
        box-shadow: 0 0 10px rgba(0,0,0,0.4);
        display: none;
    }
</style>
</head>

<body>

<button id="magicButton">☕ Café Magic: OFF</button>

<div id="menuBoard">
<h3>☕ Café Menu</h3>
<ul>
<li>Latte</li>
<li>Matcha</li>
<li>Hot Chocolate</li>
<li>Croissant</li>
<li>Cinnamon Roll</li>
</ul>
</div>

<div class="overlay">

<h1>🐾☕ Welcome to Your Warm Cat Café Forest ☕🐾</h1>
<p>A golden morning, soft moss, warm lights… and a tiny café cat keeping you company.</p>

<div class="section">
<h2>🌼 Quick Links</h2>
<ul>
<li><a href="https://www.google.com" target="_blank">Google</a></li>
<li><a href="https://classroom.google.com" target="_blank">Google Classroom</a></li>
<li><a href="https://drive.google.com" target="_blank">Google Drive</a></li>
<li><a href="https://music.youtube.com" target="_blank">YouTube Music</a></li>
<li><a href="https://www.pinterest.com" target="_blank">Moodboard</a></li>
</ul>
</div>

<div class="section">
<h2>🍄 Daily Forest Thought</h2>
<p>“Move gently today. Warm light and soft paws are guiding you.”</p>
</div>

<div class="section">
<h2>🌙 Little Tasks</h2>

<label><input type="checkbox" class="task" data-id="task1"> Finish one small thing</label><br>
<label><input type="checkbox" class="task" data-id="task2"> Drink water</label><br>
<label><input type="checkbox" class="task" data-id="task3"> Stretch your shoulders</label><br>
<label><input type="checkbox" class="task" data-id="task4"> Step outside for a moment</label><br>

</div>

<div class="section">
<h2>🌸 Moodboard</h2>
<p>Add your favourite images here — cats, warm drinks, moss, golden light.</p>
</div>

</div>

<!-- Cats -->
<img id="cat1" src="https://i.imgur.com/3ZQ3Z4R.png">
<img id="cat2" src="https://i.imgur.com/3ZQ3Z4R.png">

<!-- Magic Elements -->
<div class="petal"></div>
<div class="petal"></div>
<div class="petal"></div>

<div class="firefly"></div>
<div class="firefly"></div>
<div class="firefly"></div>

<div class="steam"></div>
<div class="steam"></div>

<script>
// Checkbox saving
document.querySelectorAll('.task').forEach(box => {
    const id = box.getAttribute('data-id');
    const saved = localStorage.getItem(id);
    if (saved === 'true') box.checked = true;

    box.addEventListener('change', () => {
        localStorage.setItem(id, box.checked);
    });
});

// Cat interaction
function addCatSound(cat) {
    const sounds = [
        "https://www.myinstants.com/media/sounds/cat-meow.mp3",
        "https://www.myinstants.com/media/sounds/purr.mp3"
    ];
    cat.addEventListener("click", () => {
        cat.style.transform = "scale(1.15)";
        setTimeout(() => cat.style.transform = "scale(1)", 200);
        new Audio(sounds[Math.floor(Math.random() * sounds.length)]).play();
    });
}

addCatSound(document.getElementById("cat1"));
addCatSound(document.getElementById("cat2"));

// Café Magic Toggle
let magicOn = false;

document.getElementById("magicButton").addEventListener("click", () => {
    magicOn = !magicOn;

    document.getElementById("magicButton").innerText =
        magicOn ? "☕ Café Magic: ON" : "☕ Café Magic: OFF";

    document.querySelectorAll(".petal, .firefly, .steam").forEach(el => {
        el.style.display = magicOn ? "block" : "none";
    });

    document.getElementById("menuBoard").style.display =
        magicOn ? "block" : "none";
});
</script>

</body>
</html>
